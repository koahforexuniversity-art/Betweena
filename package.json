{
  "name": "betweena",
  "version": "1.0.0",
  "description": "Betweena — Secure Escrow Platform for the Digital Economy",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "dev:debug": "nodemon --inspect server.js",
    "seed": "node -e \"require('./database').initDb().then(()=>console.log('Done.')).catch(console.error)\""
  },
  "keywords": [
    "escrow",
    "fintech",
    "payments",
    "africa"
  ],
  "author": "Betweena Inc.",
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.102.1",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "pg": "^8.20.0",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  },
  "nodemonConfig": {
    "watch": [
      "server.js",
      "routes/",
      "middleware/",
      "database.js"
    ],
    "ext": "js,json",
    "ignore": [
      "betweena.db.json",
      "node_modules/"
    ],
    "delay": "500"
  },
  "engines": {
    "node": ">=16.0.0"
  }
}
