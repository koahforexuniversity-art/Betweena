# Betweena Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git

# Server
PORT=3000
NODE_ENV=development

# Security — CHANGE THIS in production (min 32 chars, random string)
JWT_SECRET=betweena-dev-secret-key-change-this-in-production-min-32-chars

# Database (future - PostgreSQL)
# DATABASE_URL=postgresql://user:password@localhost:5432/betweena

# Payment Gateways (add when ready)
# PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
# STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# Email (add when ready)
# SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
# EMAIL_FROM=noreply@betweena.com

# MTN Mobile Money (add when ready)
# MTN_MOMO_API_KEY=xxxxxxxxxx
# MTN_MOMO_SUBSCRIPTION_KEY=xxxxxxxxxx

# App URL
APP_URL=http://localhost:3000
